PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:password@localhost:5432/ticketing_tool
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Welcome emails (new user creation): set these to actually send the welcome email with password.
# If not set, user is still created; in development the temporary password is logged to the server console.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# MAIL_FROM=noreply@yourdomain.com

# AI Assist (Create ticket from prompt): set to your OpenAI API key to use GPT for parsing ticket prompts.
# If not set, the AI Assist button still works and uses your text as title/description.
# OPENAI_API_KEY=
